# OpenRouter API key
# Get it at https://openrouter.ai
OPENROUTER_API_KEY=

# Model string — passed to OpenRouter
# DeepSeek via OpenRouter (cheap, reliable JSON mode, ~$0.14/1M tokens):
VEEN_AI_MODEL=deepseek/deepseek-v4-flash
# Step up to pro for more precise filtering: deepseek/deepseek-v4-pro

# Minimum relevance score to include an article (0.0–1.0)
VEEN_SCORE_THRESHOLD=0.4

# Articles per AI batch call
VEEN_BATCH_SIZE=25
